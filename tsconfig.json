{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["./src/**/*.ts", "src/config.ts", "lib/schema.ts"],
  "exclude": ["node_modules"]
}